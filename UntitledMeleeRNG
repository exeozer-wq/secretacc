local function startAutoDungeon()
    if autoDungeonRunning then return end
    print("[AutoDungeon] Starting - selected: " .. selectedDungeon)
    autoDungeonRunning = true

    autoDungeonThread = task.spawn(function()
        while autoDungeonRunning do
            print("[AutoDungeon] Cycle start - TP to dungeon")
            teleportTo(dungeons[selectedDungeon])

            -- Wait for character to load properly after TP
            task.wait(3)
            local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
            local hrp = char:WaitForChild("HumanoidRootPart", 8)
            if not hrp then
                print("[AutoDungeon] No HRP after TP - retrying cycle")
                task.wait(2)
                continue
            end

            task.wait(12)  -- total ~15s for area load / portal animation etc.

            -- Wait for mobs to actually spawn in
            print("[AutoDungeon] Waiting for mobs to load...")
            local mobsFolder = workspace:FindFirstChild("Mobs")
            local mobWait = 0
            while autoDungeonRunning and mobWait < 10 do
                mobsFolder = workspace:FindFirstChild("Mobs")
                if mobsFolder and #mobsFolder:GetChildren() > 0 then
                    print("[AutoDungeon] Mobs detected, waiting 2s then killing")
                    task.wait(2)
                    break
                end
                task.wait(1)
                mobWait += 1
            end

            -- Instant kill all mobs once
            print("[AutoDungeon] Instant killing all mobs")

            local ReplicatedStorage = game:GetService("ReplicatedStorage")
            local remotes = ReplicatedStorage:FindFirstChild("Remotes")
            local HitMob = remotes and remotes:FindFirstChild("HitMob")
            local assets = ReplicatedStorage:FindFirstChild("Assets")
            local weapons = assets and assets:FindFirstChild("Weapons")
            local weapon = weapons and weapons:FindFirstChild("Rusty Sword")
            mobsFolder = workspace:FindFirstChild("Mobs")

            if HitMob and weapon and mobsFolder then
                local damage = 999999999
                local targets = {}
                local hitCount = 0

                for _, mob in mobsFolder:GetChildren() do
                    if not mob:IsA("Model") then continue end

                    local mobId =
                        mob:GetAttribute("Id") or mob:GetAttribute("ID") or
                        mob:GetAttribute("MobId") or mob:GetAttribute("UUID") or
                        mob:GetAttribute("Identifier") or mob:GetAttribute("mobId")

                    if typeof(mobId) == "string" and #mobId >= 4 then
                        targets[mobId] = mob
                        HitMob:FireServer({{ mobId, damage, weapon }})
                        hitCount += 1
                    end
                end

                print("[AutoDungeon] Hit " .. hitCount .. " mob(s), waiting for server...")

                task.wait(2.0)  -- wait for server to process & rewards

                for _, mob in pairs(targets) do
                    if mob and mob.Parent then
                        mob:Destroy()
                    end
                end
            else
                print("[AutoDungeon] Missing HitMob/weapon/mobs - skipping kill step")
            end

            task.wait(12)

            -- Wait for game to auto-return us to lobby
            print("[AutoDungeon] Waiting for game auto-return to lobby...")

            local safetyTimeout = 0
            local maxSafety = 20

            while autoDungeonRunning and safetyTimeout < maxSafety do
                local mobs = workspace:FindFirstChild("Mobs")
                if not mobs or #mobs:GetChildren() == 0 then
                    print("[AutoDungeon] Detected back in lobby (no mobs)")
                    break
                end
                task.wait(1)
                safetyTimeout = safetyTimeout + 1
            end

            if safetyTimeout >= maxSafety then
                print("[AutoDungeon] Safety timeout - forcing next cycle")
            end

            task.wait(4)  -- settle time after return

            print("[AutoDungeon] Ready for next cycle")
        end

        print("[AutoDungeon] Auto Dungeon stopped")
    end)
end

local function stopAutoDungeon()
