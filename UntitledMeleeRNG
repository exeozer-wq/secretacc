                local firesPerThread = math.ceil(TOTAL_FIRES / THREAD_COUNT)

                for _ = 1, THREAD_COUNT do
                    task.spawn(function()
                        for i = 1, firesPerThread do
                            HitMob:FireServer(unpack(args))
                        end
                    end)
                end

                task.wait(2.0)  -- minimal safe wait for rewards; increase to 2.5–3 if missing money

                for _, mob in pairs(targets) do
                    if mob and mob.Parent then
                        mob:Destroy()
                    end
                end

                -- Optional full nuke
                -- for _, obj in mobsFolder:GetChildren() do if obj:IsA("Model") then obj:Destroy() end end

                WindUI:Notify({
                    Title = "Burst Complete",
                    Content = "Sent ~" .. TOTAL_FIRES .. " hits\nLocal cleanup done",
                    Icon = "check-circle",
                    Duration = 5
                })
            end)
        end
    })

    MainTab:Space()

    local AutoLootToggle = MainTab:Toggle({
        Title = "Auto Loot",
        Value = false,
        Callback = function(enabled)
            print("[Toggle Callback] Auto Loot toggled → enabled = " .. tostring(enabled))
            if enabled then
                task.spawn(StartAutoLoot)
            else
                StopAutoLoot()
            end
        end
    })

    local MainSection2 = MainTab:Section({
        Title = "Mana",
        Opened = true
    })

    MainTab:Button({
        Title = "Convert all MP to SP",
        Icon = "zap",
        Color = Color3.fromHex("#b801d4"),  -- red = aggressive
        Callback = function()
            task.spawn(function()
                local ReplicatedStorage = game:GetService("ReplicatedStorage")
                local Remotes = ReplicatedStorage:WaitForChild("Remotes")
                local ConvertMana = Remotes:WaitForChild("ConvertMana")
                
                local leaderstats = LocalPlayer:WaitForChild("leaderstats")
                local manaValue   = leaderstats:WaitForChild("\240\159\159\163 Mana")
                
                local manaAtStart = manaValue.Value
                if manaAtStart < 10 then
                    WindUI:Notify({Title = "Not enough", Content = "Need at least 10 MP", Duration = 4})
