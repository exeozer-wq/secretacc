local autoLootRunning = false
local lootThread = nil

local function fireLoot(part)
    print("[AutoLoot] Attempting to fire touch on: " .. part:GetFullName())
    
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    
    local touchingPart = root or part  -- fallback to self-fire
    
    firetouchinterest(touchingPart, part, 0)
    firetouchinterest(touchingPart, part, 1)
    
    print("[AutoLoot] Fired double touchinterest on " .. part.Name .. " (from " .. touchingPart.Name .. ")")
end

local function StartAutoLoot()
    print("[AutoLoot] StartAutoLoot called!")
    
    if autoLootRunning then
        print("[AutoLoot] Already running, ignoring start")
        return
    end
    
    autoLootRunning = true
    print("[AutoLoot] autoLootRunning = true")
    
    lootThread = task.spawn(function()
        print("[AutoLoot] Coroutine/Thread started")
        
        while autoLootRunning do
            print("[AutoLoot] Loop iteration started")
            
            local char = LocalPlayer.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then
                print("[AutoLoot] No character or HRP → waiting")
                task.wait(1)
                continue
            end
            
            if not workspace:FindFirstChild("Loot") then
                print("[AutoLoot] workspace.Loot missing → waiting")
                task.wait(2)
                continue
            end
            
            local firedCount = 0
            
            local success, err = pcall(function()
                for _, model in ipairs(workspace.Loot:GetChildren()) do
                    if not autoLootRunning then break end
                    
                    if not model:IsA("Model") then continue end
                    
                    -- Scan ALL descendants for ANY BasePart with TouchInterest/Transmitter
                    for _, part in ipairs(model:GetDescendants()) do
                        if not autoLootRunning then break end
                        
                        if part:IsA("BasePart") then
                            local interest = part:FindFirstChild("TouchInterest") or part:FindFirstChild("TouchTransmitter")
                            if interest then
                                fireLoot(part)
                                firedCount += 1
                                
                                task.wait(0.03)  -- tiny per-fire delay (anti-spam)
                            end
                        end
                    end
                end
            end)
            
            if firedCount > 0 then
                print(string.format("[AutoLoot] This cycle: fired %d loots", firedCount))
            else
                print("[AutoLoot] This cycle: no valid loot found")
            end
            
            if not success then
                warn("[AutoLoot] Error in loop: " .. tostring(err))
            end
            
            task.wait(0.4)  -- main throttle (~2.5 cycles/sec)
        end
        
        print("[AutoLoot] Loop exited cleanly")
    end)
end

local function StopAutoLoot()
    print("[AutoLoot] StopAutoLoot called!")
    autoLootRunning = false
    
    if lootThread then
        task.cancel(lootThread)
        lootThread = nil
        print("[AutoLoot] Thread cancelled")
    end
end


-- Mob Aura (continuous, fast spam + aggressive local cleanup)
local mobAura = {}
mobAura.running = false
mobAura.thread  = nil

function mobAura.Start()
    if mobAura.running then return end

    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local remotes = ReplicatedStorage:FindFirstChild("Remotes")
    local HitMob  = remotes and remotes:FindFirstChild("HitMob")
    
    local weapon
    local assets = ReplicatedStorage:FindFirstChild("Assets")
    if assets then
        local weaponsFolder = assets:FindFirstChild("Weapons")
        if weaponsFolder then
            weapon = weaponsFolder:FindFirstChild("Rusty Sword")  -- change name if different
        end
    end

    local mobsFolder = workspace:FindFirstChild("Mobs")

    if not (HitMob and weapon and mobsFolder) then
        return  -- silent fail (no warn)
    end

    mobAura.running = true

    mobAura.thread = task.spawn(function()
        local damage = 999999

        while mobAura.running do
            local hit_datas = {}
            local targets = {}  -- mobId → mob (for cleanup)

            for _, mob in mobsFolder:GetChildren() do
                if not mob:IsA("Model") then continue end

                local id = 
                    mob:GetAttribute("Id") or mob:GetAttribute("ID") or
                    mob:GetAttribute("MobId") or mob:GetAttribute("UUID") or
                    mob:GetAttribute("Identifier") or mob:GetAttribute("mobId")

                if typeof(id) == "string" and #id >= 4 then
                    targets[id] = mob
                    table.insert(hit_datas, {id, damage, weapon})
                end
            end

            if #hit_datas > 0 and mobAura.running then
                local args = {hit_datas}

                local BURST_SIZE       = 25   -- calls per mini-burst
                local CYCLES_PER_LOOP  = 50    -- total ~200 calls per collection
                local INTRA_BURST_WAIT = 0.08

                for c = 1, CYCLES_PER_LOOP do
                    if not mobAura.running then break end

                    for i = 1, BURST_SIZE do
                        if not mobAura.running then break end
                        task.spawn(HitMob.FireServer, HitMob, unpack(args))
                    end

                    if mobAura.running then
                        task.wait(INTRA_BURST_WAIT)
                    end
                end

                -- Aggressive local cleanup (destroy if still parented)
                if mobAura.running then
                    task.wait(0.35)  -- short delay after spam

                    for _, mob in pairs(targets) do
                        if mobAura.running and mob and mob.Parent then
                            mob:Destroy()
                        end
                    end
                end
            else
                task.wait(1.1)  -- no targets → wait longer
            end

            if mobAura.running then
                task.wait(0.9)  -- main loop throttle
            end
        end

        -- Final cleanup on exit (catches anything left from last burst)
        if mobsFolder then
            for _, mob in mobsFolder:GetChildren() do
                if mob:IsA("Model") then
                    mob:Destroy()
                end
            end
        end

        mobAura.thread = nil
    end)
end


function mobAura.Stop()
    local wasRunning = mobAura.running
    mobAura.running = false

    if mobAura.thread then
        task.cancel(mobAura.thread)
        mobAura.thread = nil
    end

    -- Extra immediate cleanup when turning off
    if wasRunning then
        local mobsFolder = workspace:FindFirstChild("Mobs")
        if mobsFolder then
            for _, mob in mobsFolder:GetChildren() do
                if mob:IsA("Model") then
                    mob:Destroy()
                end
            end
        end
    end
end


