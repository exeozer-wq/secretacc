    if autoDungeonThread then
        task.cancel(autoDungeonThread)
        autoDungeonThread = nil
    end
    mobAura.Stop()   -- ensure it's cleanly stopped
end



-- auto ascend
local leaderstats = LocalPlayer:WaitForChild("leaderstats")
local ascendsValue = leaderstats:WaitForChild("\240\159\140\159 Ascends")
local killsValue = leaderstats:WaitForChild("\240\159\142\175 Kills")

local autoAscendEnabled = false
local autoAscendConnection = nil

local function getRequiredKills(currentAscends)
    return (currentAscends + 2) * 1000000   -- 2M at 0, 3M at 1, 4M at 2, etc.
end

local function checkAndAscend()
    if not autoAscendEnabled then return end
    
    local currentAscends = ascendsValue.Value
    local currentKills = killsValue.Value
    local required = getRequiredKills(currentAscends)

    print(string.format("[AutoAscend] Checking: Ascends=%d | Kills=%d / Required=%d", 
        currentAscends, currentKills, required))
    
    if currentKills >= required then
        print("[AutoAscend] Threshold met → invoking ConfirmAscend")
        
        local success, err = pcall(function()
            local Remotes = game:GetService("ReplicatedStorage"):WaitForChild("Remotes")
            local ConfirmAscend = Remotes:WaitForChild("ConfirmAscend")
            ConfirmAscend:InvokeServer()
        end)
        
        if success then
            -- No notification on success
        else
            warn("[AutoAscend] Invoke failed: " .. tostring(err))
            -- No error popup either — only console warning
        end
    end
end

local function toggleAutoAscend(enabled)
    autoAscendEnabled = enabled
    
    if enabled then
        -- Initial check
        checkAndAscend()
        
        -- Connect to changes (debounced to avoid spam)
        autoAscendConnection = killsValue.Changed:Connect(function()
            task.wait(0.5)  -- debounce
            checkAndAscend()
        end)
        
        ascendsValue.Changed:Connect(function()
            task.wait(1)  -- longer debounce on ascend
            checkAndAscend()
        end)
        
        print("[AutoAscend] Enabled")
    else
        if autoAscendConnection then
            autoAscendConnection:Disconnect()
            autoAscendConnection = nil
        end
        print("[AutoAscend] Disabled")
    end
end


