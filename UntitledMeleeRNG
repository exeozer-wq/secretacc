    })

    local MainSection1 = MainTab:Section({
        Title = "Main",
        Opened = true
    })

    MainTab:Space()

    MainTab:Toggle({
        Title = "KillAura",
        Desc = "automatically hits all spawned mobs, might take slightly longer in dungeon depending on boss's HP",
        Icon = "zap",
        Default = false,
        Callback = function(value)
            KillAuraEnabled = value

            if value then
                if KillAuraThread then return end

                KillAuraThread = task.spawn(function()
                    local ReplicatedStorage = game:GetService("ReplicatedStorage")
                    local Remotes = ReplicatedStorage:WaitForChild("Remotes")
                    local HitMob = Remotes:WaitForChild("HitMob")
                    local Assets = ReplicatedStorage:WaitForChild("Assets")
                    local Weapons = Assets:WaitForChild("Weapons")
                    local weapon = Weapons:WaitForChild("Hellscape Greatsword")
                    local dmgMult = 1
                    local success, result = pcall(function()
                        return 1 + Remotes:GetUpgradeValue():InvokeServer("Damage Multiplier") / 100
                    end)
                    if success then dmgMult = result end

                    local stopScript = false
                    local args = {}
                    local mobsLocation = nil
                    local enemyTable = {}
                    local currEnemies = {}
                    local spawnMobConnection

                    -- Mob spawn event connection
                    if Remotes:FindFirstChild("SpawnMob") then
                        spawnMobConnection = Remotes.SpawnMob.OnClientEvent:Connect(function(mob)
                            if mob.ID then
                                enemyTable[mob.ID] = mob.Health or 10000000
                                currEnemies[mob.ID] = true
                            end
                        end)
                    end

                    WindUI:Notify({
                        Title = "KillAura",
                        Content = "Activated. Will clean up mobs and connections on stop.",
                        Icon = "zap",
                        Duration = 4
                    })

                    while KillAuraEnabled do
                        -- Find mobs location
                        if workspace:FindFirstChild("Mobs") then
                            mobsLocation = workspace.Mobs
                        elseif ReplicatedStorage:FindFirstChild("Mobs") then
                            mobsLocation = ReplicatedStorage.Mobs
                        else
                            mobsLocation = nil
                        end

                        if not mobsLocation then
                            task.wait(0.1)
                            continue
                        end

                        local damage = dmgMult * (weapon:GetAttribute("Damage") or 100) * 4
                        for _, v in pairs(mobsLocation:GetChildren()) do
                            if v and v.ClassName == "Model" and v:FindFirstChild("HumanoidRootPart") then
                                local mobID = v:GetAttribute("ID")
                                if mobID then
                                    table.insert(args, { mobID, damage, weapon })
                                    currEnemies[mobID] = true
                                    local enemy = enemyTable[mobID]
                                    if enemy then
                                        enemyTable[mobID] = enemy - damage
                                    else
                                        enemyTable[mobID] = 10000000 - damage
                                    end
                                    if enemy and enemy <= 0 then
                                        pcall(function()
                                            if v and v.Parent then v:Destroy() end
                                        end)
                                        enemyTable[mobID] = nil
                                    end
                                end
                            end
                        end

                        for i, v in pairs(enemyTable) do
                            if not currEnemies[i] then
                                enemyTable[i] = nil
                            end
                        end
                        currEnemies = {}

                        if #args > 0 then
                            pcall(function()
                                HitMob:FireServer(args)
                            end)
                        end
                        args = {}
                        task.wait(0.1)
                    end

                    -- Cleanup
                    if spawnMobConnection then spawnMobConnection:Disconnect() end
                    WindUI:Notify({
                        Title = "KillAura",
                        Content = "Stopped and cleaned up.",
                        Icon = "power",
                        Duration = 3
                    })
                    KillAuraThread = nil
                end)
            end
        end
    })

    MainTab:Space()

    local MainSection2 = MainTab:Section({
        Title = "Mana",
        Opened = true
    })

    MainTab:Button({
        Title = "Convert all MP to SP",
        Icon = "zap",
        Color = Color3.fromHex("#b801d4"),  -- red = aggressive
        Callback = function()
            task.spawn(function()
                local ReplicatedStorage = game:GetService("ReplicatedStorage")
                local Remotes = ReplicatedStorage:WaitForChild("Remotes")
                local ConvertMana = Remotes:WaitForChild("ConvertMana")
                
                local leaderstats = LocalPlayer:WaitForChild("leaderstats")
                local manaValue   = leaderstats:WaitForChild("\240\159\159\163 Mana")
                
                local manaAtStart = manaValue.Value
                if manaAtStart < 10 then
                    WindUI:Notify({Title = "Not enough", Content = "Need at least 10 MP", Duration = 4})
                    return
                end
                
                WindUI:Notify({
                    Title = "Mana → SP",
                    Content = "Starting..",
                    Duration = 3
                })
                
                local BATCH_COUNT = 80   -- tune: 40–150; too high = invocation queue exhausted error
                local PER_CALL    = 10
                
                for i = 1, BATCH_COUNT do
                    task.spawn(function()
                        pcall(ConvertMana.InvokeServer, ConvertMana, PER_CALL)
                    end)
                end
                
                -- Give some time for server to process & replicate mana back
                task.wait(1.4)
                
                local convertedApprox = manaAtStart - manaValue.Value
                WindUI:Notify({
                    Title = "Done (approx)",
                    Content = "Started with " .. manaAtStart .. " MP\nLikely converted ~" .. convertedApprox .. " MP",
                    Icon = "check-circle",
                    Duration = 7
                })
            end)
        end
    })
