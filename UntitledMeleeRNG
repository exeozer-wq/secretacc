                WindUI:Notify({Title = "Duped sword.", Content = "-" .. savedArgs.amount, Duration = 2.5})
            else
                warn("[Dupe] FountainSacrifice remote missing!")
            end
        end
    })

    -- Sell button (+amount)
    ControlsSection:Button({
        Title = "Sell - gives Skill points; takes sword from you.",
        Color = Color3.fromHex("#30ff6a"),
        Callback = function()
            if savedArgs.amount <= 0 then
                WindUI:Notify({Title = "Invalid Amount", Content = "Amount must be > 0", Duration = 4})
                return
            end
            local args = { savedArgs.weapon, savedArgs.mode, savedArgs.amount }
            local remotes = game:GetService("ReplicatedStorage"):WaitForChild("Remotes")
            local remote = remotes:FindFirstChild("FountainSacrifice")
            if remote then
                remote:InvokeServer(unpack(args))
                WindUI:Notify({Title = "Sold sword.", Content = "+" .. savedArgs.amount, Duration = 2.5})
            else
                warn("[Dupe] FountainSacrifice remote missing!")
            end
        end
    })


    ControlsSection:Space()

    ControlsSection:Button({
        Title = "Print all weapon names in console (F9)",
        Callback = function()
            -- Get the weapons folder
            local weaponsFolder = game:GetService("ReplicatedStorage"):FindFirstChild("Assets")
                and game:GetService("ReplicatedStorage").Assets:FindFirstChild("Weapons")

            if not weaponsFolder then
                warn("[Weapon List] Weapons folder not found in ReplicatedStorage.Assets!")
                return
            end

            -- Function to determine rarity based on OneIn value
            local function getRarity(oneInValue)
                if oneInValue >= 1000000 then return "Mythical"
                elseif oneInValue >= 100000 then return "Legendary"
                elseif oneInValue >= 10000 then return "Epic"
                elseif oneInValue >= 1000 then return "Rare"
                elseif oneInValue >= 100 then return "Uncommon"
                else return "Common" end
            end

            -- Create tables to store weapon data by rarity
            local weaponsByRarity = {
                Mythical = {},
                Legendary = {},
                Epic = {},
                Rare = {},
                Uncommon = {},
                Common = {}
            }

            -- Iterate through all weapons
            local found = 0
            for _, weapon in ipairs(weaponsFolder:GetChildren()) do
                if weapon:IsA("Model") then
                    local damage = weapon:GetAttribute("Damage")
                    local oneIn  = weapon:GetAttribute("OneIn")
                    local rank   = weapon:GetAttribute("Rank")

                    if damage and oneIn then
                        local rarity = getRarity(oneIn)
                        table.insert(weaponsByRarity[rarity], {
                            name   = weapon.Name,
                            damage = damage,
                            oneIn  = oneIn,
                            rank   = rank,
                            rarity = rarity
                        })
                        found = found + 1
                    end
                end
            end

            if found == 0 then
                print("[Weapon List] No weapons with Damage & OneIn attributes found.")
                return
            end

            -- Print header
            print("=== WEAPONS BY RARITY (" .. found .. " total valid weapons) ===\n")

            -- Print in order from rarest to common
            local rarityOrder = {"Mythical", "Legendary", "Epic", "Rare", "Uncommon", "Common"}

            for _, rarity in ipairs(rarityOrder) do
                local weapons = weaponsByRarity[rarity]
                if #weapons > 0 then
                    -- Sort by OneIn descending (higher = rarer within tier)
                    table.sort(weapons, function(a, b)
                        return a.oneIn > b.oneIn
                    end)

                    print("=== " .. string.upper(rarity) .. " (" .. #weapons .. ") ===")

                    for _, w in ipairs(weapons) do
                        print(string.format(
                            "%-28s | Dmg: %-6s | 1/%-8s | Rank: %s",
                            w.name,
                            tostring(w.damage),
                            tostring(w.oneIn),
                            w.rank or "N/A"
                        ))
                    end
                    print("")  -- separator between rarity groups
                end
            end

            -- Summary
            print("=== SUMMARY ===")
            local total = 0
            for _, rarity in ipairs(rarityOrder) do
                local count = #weaponsByRarity[rarity]
                if count > 0 then
                    print(rarity .. ": " .. count)
                    total = total + count
                end
            end
            print("Total weapons found: " .. total)
            print("───────────────────────────────────────────────")
        end
    })

end




